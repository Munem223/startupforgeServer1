    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "7.0.0",
    "morgan": "1.10.1",
    "multer": "2.0.2",
    "stripe": "20.1.0",
    "zod": "4.3.6"
